# Zone backend
DATABASE_URL=postgresql://root@localhost:26257/vsekai?sslmode=disable
URL=https://vsekai.local/api/v1/
ROOT_ORIGIN=https://vsekai.local
FRONTEND_URL=https://vsekai.local/
PORT=4000

# S3 (MinIO local)
AWS_S3_BUCKET=uro-uploads
AWS_S3_ENDPOINT=http://localhost:7070
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Godot zone server WebTransport — self-signed cert hash (printed at zone server startup)
ZONE_CERT_HASH_B64=
