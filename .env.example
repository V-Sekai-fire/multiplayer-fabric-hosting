# Cloudflare Tunnel — get token from https://one.dash.cloudflare.com/ → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# Zone backend public URLs — must match the hostname configured in the Cloudflare Tunnel dashboard
URL=https://vsekai.example.com/api/v1/
ROOT_ORIGIN=https://vsekai.example.com
FRONTEND_URL=https://vsekai.example.com/

# S3 (versitygw local — credentials only matter for the local gateway)
AWS_S3_BUCKET=uro-uploads
AWS_S3_ENDPOINT=http://localhost:7070
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Godot zone server WebTransport — self-signed cert hash (printed at zone server startup)
ZONE_CERT_HASH_B64=
