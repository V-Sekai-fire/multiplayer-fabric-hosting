# Zone backend public URLs — must match the public hostname
URL=https://vsekai.example.com/api/v1/
ROOT_ORIGIN=https://vsekai.example.com
FRONTEND_URL=https://vsekai.example.com/

# Signing keys — generate with `mix phx.gen.secret` or https://randomkeygen.com/ (min 256-bit entropy)
PHOENIX_KEY_BASE=bNDe+pg86uL938fQA8QGYCJ4V7fE5RAxoQ8grq9drPpO7mZ0oEMSNapKLiA48smR
JOKEN_SIGNER=gqawCOER09ZZjaN8W2QM9XT9BeJSZ9qc

# Seeded accounts — created on first boot by the uro init script
ADMIN_PASSWORD=
USER_PASSWORD=

# S3 (versitygw local — generate with `openssl rand -hex 16` or similar)
AWS_S3_BUCKET=uro-uploads
AWS_S3_ENDPOINT=http://versitygw:7070
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Cloudflare Turnstile CAPTCHA — https://developers.cloudflare.com/turnstile/get-started/
# TURNSTILE_SITEKEY is sent to the Next.js frontend (public).
# TURNSTILE_SECRET_KEY is used by Uro for server-side token verification (keep secret).
# Defaults below are the "always pass" test keys — replace for production.
TURNSTILE_SITEKEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Godot zone server WebTransport (optional embedded zone — docker compose --profile zone up)
# Zone servers have multiplicity 0..∞. Each registers itself with Uro at startup;
# no static list is needed for the base hub deployment.
# Set these only when running the embedded zone-server profile:
ZONE_HOST=zone.example.com
ZONE_PORT=443

# Sendgrid email service API key — leave empty to disable outbound email
SENDGRID_API_KEY=

# Game client signup key — leave empty to disable game client registration
SIGNUP_API_KEY=

# Baker (zone spawner) token — leave empty to disable automatic zone spawning
BAKER_TOKEN=

# OAuth2 — GitHub (leave empty to disable)
OAUTH2_GITHUB_CLIENT_ID=
OAUTH2_GITHUB_CLIENT_SECRET=

# OAuth2 — Discord (leave empty to disable)
OAUTH2_DISCORD_CLIENT_ID=
OAUTH2_DISCORD_CLIENT_SECRET=

# Cloudflare Tunnel — disabled by default (direct port-443 TLS preferred).
# Uncomment the cloudflared service in docker-compose.yml if direct port forwarding is unavailable.
CLOUDFLARE_TUNNEL_TOKEN=
