# HTTPS with Cloudflare Origin Certificate.
# Cloudflare acts as reverse proxy (orange cloud); SSL mode must be Full (strict).
hub-700a.chibifire.com {
	tls /etc/caddy/certs/origin.crt /etc/caddy/certs/origin.key

	# Phoenix API (path prefix stripped before proxying)
	handle_path /api/v1/* {
		reverse_proxy uro:4000
	}

	# Waffle/S3 uploads served through Phoenix
	handle /uploads/* {
		reverse_proxy uro:4000
	}

	# aria-storage chunk server (replaces desync) — content-addressed zone asset chunks
	handle /chunks/* {
		reverse_proxy uro:4000
	}

	# Everything else → Next.js frontend
	handle {
		reverse_proxy frontend:3000
	}
}
